#!/usr/bin/env bash
# Update remote environment(s) using ansible-playbook.
# Optionally pass role names.
set -e

DOTFILES_DIR=~/dotfiles
REMOTE_HOST=mac-mini
REMOTE_USER=stevenloria

echo "Syncing dotfiles to '$REMOTE_HOST'..."
rsync -a --delete --exclude='.git' "$DOTFILES_DIR/" "${REMOTE_USER}@${REMOTE_HOST}:~/dotfiles/"

if [[ $# -eq 0 ]]; then
  echo "Updating remote environment(s)..."
  ansible-playbook "$DOTFILES_DIR/provision.yaml" -i "$DOTFILES_DIR/hosts.ini" -i "$DOTFILES_DIR/hosts.local.ini" --limit remote
else
  echo "Updating remote environment(s)... (--tags $@)"
  ansible-playbook "$DOTFILES_DIR/provision.yaml" -i "$DOTFILES_DIR/hosts.ini" -i "$DOTFILES_DIR/hosts.local.ini" --limit remote --tags $@
fi
