theme = dark:Night Owl,light:Light Owl
# Block cursor
# Need both options, per https://github.com/ghostty-org/ghostty/discussions/3836#discussioncomment-11688264
cursor-style = block
shell-integration-features = no-cursor

# Make ctrl+[ work for Esc as expected
keybind = ctrl+[=text:\x1b

# Don't require confirming close
confirm-close-surface = false

# Disable ligatures
font-feature = -calt,-liga,-dlig

# Notify after commands finish
notify-on-command-finish-action = notify
notify-on-command-finish = unfocused
